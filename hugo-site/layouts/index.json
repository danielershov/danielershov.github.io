{{- $pages := where .Site.RegularPages "Params.private" "ne" true -}}
[
{{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "section": {{ $p.Section | jsonify }},
    "summary": {{ ($p.Params.abstract | default $p.Summary) | plainify | jsonify }}
  }
{{- end -}}
]
